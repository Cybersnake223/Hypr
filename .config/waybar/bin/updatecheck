## | $$   \$$ \$$\/  $$ | $$__/ $$| $$__    | $$__| $$| $$___\$$| $$$\| $$| $$__| $$| $$/  $$ | $$__      ##
## | $$        \$$  $$  | $$    $$| $$  \   | $$    $$ \$$    \ | $$$$\ $$| $$    $$| $$  $$  | $$  \     ##
## | $$   __    \$$$$   | $$$$$$$\| $$$$$   | $$$$$$$\ _\$$$$$$\| $$\$$ $$| $$$$$$$$| $$$$$\  | $$$$$     ##
## | $$__/  \   | $$    | $$__/ $$| $$_____ | $$  | $$|  \__| $$| $$ \$$$$| $$  | $$| $$ \$$\ | $$_____   ##
##  \$$    $$   | $$    | $$    $$| $$     \| $$  | $$ \$$    $$| $$  \$$$| $$  | $$| $$  \$$\| $$     \  ##
##   \$$$$$$     \$$     \$$$$$$$  \$$$$$$$$ \$$   \$$  \$$$$$$  \$$   \$$ \$$   \$$ \$$   \$$ \$$$$$$$$  ##
##                                                                                                        ##
## Update Check For Waybar                                                                                ##
## Created by Cybersnake                                                                                  ##
############################################################################################################


# --- Dependency check ---
if ! command -v checkupdates-with-aur &>/dev/null; then
    printf '{"text":"󰮯 !","tooltip":"checkupdates-with-aur not found","class":"error"}\n'
    exit 1
fi

# --- Kill stale instances ---
pkill -x checkupdates-with-aur 2>/dev/null

# --- Pad/truncate string to fixed width ---
stringToLen() {
    local str="$1" len="$2"
    if (( ${#str} > len )); then
        printf '%s' "${str:0:$((len - 2))}.."
    else
        printf "%-${len}s" "$str"
    fi
}

# --- Fetch updates ---
IFS=$'\n' read -r -d '' -a updates < <(checkupdates-with-aur 2>/dev/null; printf '\0')
count="${#updates[@]}"

# --- Build output ---
if (( count == 0 )); then
    printf '{"text":"󰮯 0","tooltip":"<b>󰮯  System is up to date</b>","class":"updated"}\n'
    exit 0
fi

tooltip="<b>󰮯  ${count} update(s) available (Arch + AUR)</b>\n"
tooltip+="<b>$(stringToLen "Package" 25) $(stringToLen "From" 22) $(stringToLen "To" 22)</b>"

for entry in "${updates[@]}"; do
    [[ -z "$entry" ]] && continue
    pkg="$(stringToLen "$(awk '{print $1}' <<< "$entry")" 25)"
    prev="$(stringToLen "$(awk '{print $2}' <<< "$entry")" 22)"
    next="$(stringToLen "$(awk '{print $4}' <<< "$entry")" 22)"
    tooltip+="<b>${pkg}</b> <span foreground='#ff6b6b'>${prev}</span><span foreground='#6bff8e'>${next}</span>\n"
done

tooltip="${tooltip%\\n}"

printf '{"text":"󰮯 %s","tooltip":"%s","class":"pending-updates"}\n' "$count" "$tooltip"
