## |  $$$$$$\\$$\  /  $$| $$$$$$$\| $$$$$$$$| $$$$$$$\|  $$$$$$\| $$\ | $$|  $$$$$$\| $$ /  $$| $$$$$$$$  ##
## | $$   \$$ \$$\/  $$ | $$__/ $$| $$__    | $$__| $$| $$___\$$| $$$\| $$| $$__| $$| $$/  $$ | $$__      ##
## | $$        \$$  $$  | $$    $$| $$  \   | $$    $$ \$$    \ | $$$$\ $$| $$    $$| $$  $$  | $$  \     ##
## | $$   __    \$$$$   | $$$$$$$\| $$$$$   | $$$$$$$\ _\$$$$$$\| $$\$$ $$| $$$$$$$$| $$$$$\  | $$$$$     ##
## | $$__/  \   | $$    | $$__/ $$| $$_____ | $$  | $$|  \__| $$| $$ \$$$$| $$  | $$| $$ \$$\ | $$_____   ##
##  \$$    $$   | $$    | $$    $$| $$     \| $$  | $$ \$$    $$| $$  \$$$| $$  | $$| $$  \$$\| $$     \  ##
##   \$$$$$$     \$$     \$$$$$$$  \$$$$$$$$ \$$   \$$  \$$$$$$  \$$   \$$ \$$   \$$ \$$   \$$ \$$$$$$$$  ##
## Screenshot Utility                                                                                     ##
## Created by Cybersnake                                                                                  ##
############################################################################################################

set -euo pipefail

# CONFIG
ROFI_CMD=(rofi -dmenu -l 5 -p "Take A Shot")
SAVE_DIR="${HOME}/Pictures/Screenshots"
mkdir -p "$SAVE_DIR"
DELAY=0.2

# options
declare -A OPTIONS=(
  ["󰍹 Capture screen"]="screen"
  ["󰩬 Capture area"]="area"
  ["󰍷 Capture window"]="window"
  ["󱑀 Capture in 5s"]="5"
  ["󱑇 Capture in 10s"]="10"
)

# DEPENDENCY CHECK
for cmd in grim slurp rofi wl-copy notify-send hyprctl; do
  command -v "$cmd" >/dev/null || {
    echo "Missing dependency: $cmd" >&2
    exit 1
  }
done

# UTILITIES
gen_file() {
  printf "%s/%s.png" "$SAVE_DIR" "$(date +'%Y-%m-%d_%H-%M-%S')"
}

countdown() {
  local sec=$1
  while (( sec > 0 )); do
    notify-send -t 900 "Screenshot in" "$sec s remaining"
    sleep 1
    ((sec--))
  done
}

notify_done() {
  notify-send "Screenshot saved" "$1"
}

# CAPTURE
capture() {
  local geo="${1:-}" file
  file="$(gen_file)"

  if [[ -n "$geo" ]]; then
    grim -g "$geo" - | tee "$file" | wl-copy
  else
    grim - | tee "$file" | wl-copy
  fi

  notify_done "$file"
}

# MODES
capture_screen() {
  sleep $DELAY
  capture
}

capture_area() {
  local geo
  geo="$(slurp)" || exit 0
  capture "$geo"
}

capture_window() {
  local x y w h geo

  # parse hyprctl (no jq)
  while IFS=': ' read -r key rest; do
    case "$key" in
      at)   set -- $rest; x=$1; y=$2 ;;
      size) set -- $rest; w=$1; h=$2 ;;
    esac
  done < <(hyprctl activewindow)

  geo="${x},${y} ${w}x${h}"
  capture "$geo"
}

# DISPATCH
run() {
  local mode=$1

  case "$mode" in
    screen) capture_screen ;;
    area)   capture_area ;;
    window) capture_window ;;
    5|10)
      countdown "$mode"
      capture_screen
      ;;
    *) exit 1 ;;
  esac
}

# MENU
main() {
  local choice

  choice=$(printf "%s\n" "${!OPTIONS[@]}" | sort | "${ROFI_CMD[@]}") || exit 0
  run "${OPTIONS[$choice]}"
}

main
