#!/bin/bash
############################################################################################################

set -euo pipefail

dir="$HOME/Music/%(title)s.%(ext)s"

url=$(wl-paste 2>/dev/null | tr -d '[:space:]') || true
[[ -z "$url" ]] && { notify-send -u critical "ytdla" "Clipboard is empty"; exit 1; }

if ! [[ "$url" =~ ^https?:// ]]; then
    notify-send -u critical "ytdla" "Invalid URL: $url"
    exit 1
fi

confirmed=$(printf "Download\nCancel" | rofi -dmenu -p "Audio: $url")
[[ "$confirmed" != "Download" ]] && { notify-send "ytdla" "Aborted"; exit 0; }

notify-send "ytdla" "Downloading audio..."
yt-dlp -q -x --audio-quality 0 --audio-format flac -o "$dir" "$url" \
    && notify-send "ytdla" "Download complete" \
    || notify-send -u critical "ytdla" "Download failed"
