#!/bin/bash
############################################################################################################
##   ______  __      __  _______   ________  _______    ______   __    __   ______   __    __  ________   ##
##  /      \|  \    /  \|       \ |        \|       \  /      \ |  \  |  \ /      \ |  \  /  \|        \  ##
## |  $$$$$$\\$$\  /  $$| $$$$$$$\| $$$$$$$$| $$$$$$$\|  $$$$$$\| $$\ | $$|  $$$$$$\| $$ /  $$| $$$$$$$$  ##
## | $$   \$$ \$$\/  $$ | $$__/ $$| $$__    | $$__| $$| $$___\$$| $$$\| $$| $$__| $$| $$/  $$ | $$__      ##
## | $$        \$$  $$  | $$    $$| $$  \   | $$    $$ \$$    \ | $$$$\ $$| $$    $$| $$  $$  | $$  \     ##
## | $$   __    \$$$$   | $$$$$$$\| $$$$$   | $$$$$$$\ _\$$$$$$\| $$\$$ $$| $$$$$$$$| $$$$$\  | $$$$$     ##
## | $$__/  \   | $$    | $$__/ $$| $$_____ | $$  | $$|  \__| $$| $$ \$$$$| $$  | $$| $$ \$$\ | $$_____   ##
##  \$$    $$   | $$    | $$    $$| $$     \| $$  | $$ \$$    $$| $$  \$$$| $$  | $$| $$  \$$\| $$     \  ##
##   \$$$$$$     \$$     \$$$$$$$  \$$$$$$$$ \$$   \$$  \$$$$$$  \$$   \$$ \$$   \$$ \$$   \$$ \$$$$$$$$  ##
##                                                                                                        ##
##                                                                                                        ##
## Wallpaper Switcher                                                                                     ##
## Created by Cybersnake                                                                                  ##
############################################################################################################

set -euo pipefail

# ── Configuration ─────────────────────────────────────────────────────────────

DIR="${WALLPAPER_DIR:-$HOME/Pictures/Wallpapers}"
CACHE_DIR="${XDG_CACHE_HOME:-$HOME/.cache}/wallpaper-thumbs"
LAST_WALL="${XDG_CACHE_HOME:-$HOME/.cache}/last-wallpaper"
SYMLINK="$HOME/.config/hypr/wallpaper/current"
ROFI_THEME="${XDG_CONFIG_HOME:-$HOME/.config}/rofi/wall.rasi"
TRANSITION_FPS="${TRANSITION_FPS:-60}"
TRANSITION_DURATION="${TRANSITION_DURATION:-2}"
TRANSITION_TYPE="${TRANSITION_TYPE:-wipe}"
TRANSITION_POS="${TRANSITION_POS:-center}"

# ── Helpers ───────────────────────────────────────────────────────────────────

notify() { notify-send "Wallpaper" "$1"; }
die()    { notify-send -u critical "Wallpaper" "$1"; exit 1; }

# ── Preflight Checks ──────────────────────────────────────────────────────────

command -v swww   &>/dev/null || die "swww is not installed."
command -v magick &>/dev/null || die "imagemagick is not installed."
command -v fd     &>/dev/null || die "fd is not installed."
command -v rofi   &>/dev/null || die "rofi is not installed."
swww query        &>/dev/null || die "swww daemon is not running. Run: swww-daemon --format xrgb"
[[ -d "$DIR" ]]               || die "Wallpaper directory not found: $DIR"
[[ -f "$ROFI_THEME" ]]        || die "Rofi theme not found: $ROFI_THEME"

# ── Thumbnail Cache ───────────────────────────────────────────────────────────

mkdir -p "$CACHE_DIR"
mkdir -p "$(dirname "$SYMLINK")"

find "$CACHE_DIR" -name "*.png" -mtime +60 -delete &

generate_thumbnail() {
    local src="$1"
    local thumb="$CACHE_DIR/$(printf '%s' "$src" | md5sum | cut -d' ' -f1).png"
    if [[ ! -f "$thumb" ]]; then
        magick "$src" \
            -thumbnail 256x144^ \
            -gravity center \
            -extent 256x144 \
            "$thumb" 2>/dev/null || return 1
    fi
    echo "$thumb"
}

# ── Apply ─────────────────────────────────────────────────────────────────────

apply() {
    local wallpaper="$1"

    swww img "$wallpaper" \
        --transition-type     "$TRANSITION_TYPE" \
        --transition-fps      "$TRANSITION_FPS" \
        --transition-duration "$TRANSITION_DURATION" \
        --transition-step     120 \
        --transition-pos      "$TRANSITION_POS"

    echo "$wallpaper" > "$LAST_WALL"

    ln -sf "$wallpaper" "$SYMLINK"

    matugen image "$wallpaper" \
        -m dark \
        -t scheme-tonal-spot \
        --contrast 1.0 &

    notify "Applied: $(basename "$wallpaper")"
}

# ── Random Mode ───────────────────────────────────────────────────────────────
# Usage: changewall --random

if [[ "${1:-}" == "--random" ]]; then
    wallpaper=$(fd -a -i -e png -e jpg -e jpeg -e webp . "$DIR" | shuf -n 1)
    [[ -z "$wallpaper" ]] && die "No wallpapers found in: $DIR"
    apply "$wallpaper"
    exit 0
fi

# ── Build Rofi Menu ───────────────────────────────────────────────────────────

declare -A label_to_path
rofi_input=""
current=$(readlink -f "$SYMLINK" 2>/dev/null || true)

while IFS= read -r file; do
    thumb=$(generate_thumbnail "$file") || continue
    label=$(basename "$file")

    # Mark currently active wallpaper
    [[ "$file" == "$current" ]] && label="● $label"

    label_to_path["$label"]="$file"
    rofi_input+="${label}\0icon\x1f${thumb}\n"
done < <(fd -a -i -e png -e jpg -e jpeg -e webp . "$DIR" | sort)

[[ -z "$rofi_input" ]] && die "No wallpapers found in: $DIR"

# ── Show Picker ───────────────────────────────────────────────────────────────

chosen_label=$(printf "%b" "$rofi_input" \
    | rofi -dmenu -i \
           -p "󰸉  Wallpaper: " \
           -theme "$ROFI_THEME") || exit 0

[[ -z "$chosen_label" ]] && exit 0

wallpaper="${label_to_path[$chosen_label]:-}"
[[ -z "$wallpaper" ]] && die "Could not resolve: $chosen_label"

apply "$wallpaper"
