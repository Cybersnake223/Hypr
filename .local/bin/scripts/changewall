#!/bin/bash
############################################################################################################
##   ______  __      __  _______   ________  _______    ______   __    __   ______   __    __  ________   ##
##  /      \|  \    /  \|       \ |        \|       \  /      \ |  \  |  \ /      \ |  \  /  \|        \  ##
## |  $$$$$$\\$$\  /  $$| $$$$$$$\| $$$$$$$$| $$$$$$$\|  $$$$$$\| $$\ | $$|  $$$$$$\| $$ /  $$| $$$$$$$$  ##
## | $$   \$$ \$$\/  $$ | $$__/ $$| $$__    | $$__| $$| $$___\$$| $$$\| $$| $$__| $$| $$/  $$ | $$__      ##
## | $$        \$$  $$  | $$    $$| $$  \   | $$    $$ \$$    \ | $$$$\ $$| $$    $$| $$  $$  | $$  \     ##
## | $$   __    \$$$$   | $$$$$$$\| $$$$$   | $$$$$$$\ _\$$$$$$\| $$\$$ $$| $$$$$$$$| $$$$$\  | $$$$$     ##
## | $$__/  \   | $$    | $$__/ $$| $$_____ | $$  | $$|  \__| $$| $$ \$$$$| $$  | $$| $$ \$$\ | $$_____   ##
##  \$$    $$   | $$    | $$    $$| $$     \| $$  | $$ \$$    $$| $$  \$$$| $$  | $$| $$  \$$\| $$     \  ##
##   \$$$$$$     \$$     \$$$$$$$  \$$$$$$$$ \$$   \$$  \$$$$$$  \$$   \$$ \$$   \$$ \$$   \$$ \$$$$$$$$  ##
##                                                                                                        ##
##                                                                                                        ##
## Wallpaper Switcher                                                                                     ##
## Created by Cybersnake                                                                                  ##
############################################################################################################

set -euo pipefail

# ── Configuration ─────────────────────────────────────────────────────────────

DIR="${WALLPAPER_DIR:-$HOME/Pictures/Wallpapers}"
CACHE_DIR="${XDG_CACHE_HOME:-$HOME/.cache}/wallpaper-thumbs"
LAST_WALL="${XDG_CACHE_HOME:-$HOME/.cache}/last-wallpaper"
ROFI_THEME="${XDG_CONFIG_HOME:-$HOME/.config}/rofi/wall.rasi"
HYPR_WALL_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/hypr/wallpaper"
HYPRPAPER_CONF="${XDG_CONFIG_HOME:-$HOME/.config}/hypr/hyprpaper.conf"
TRANSITION_FPS="${TRANSITION_FPS:-60}"
TRANSITION_DURATION="${TRANSITION_DURATION:-2}"
TRANSITION_TYPE="${TRANSITION_TYPE:-wipe}"
TRANSITION_POS="${TRANSITION_POS:-center}"

# ── Helpers ───────────────────────────────────────────────────────────────────

die()     { notify-send -u critical -i dialog-error "changewall" "$1"; exit 1; }
success() { notify-send -i image "changewall" "$1"; }

thumb_path() {
    local hash
    hash=$(md5sum "$1" | cut -d' ' -f1)
    echo "$CACHE_DIR/${hash}.png"
}

# ── Preflight Checks ──────────────────────────────────────────────────────────

command -v awww        &>/dev/null || die "awww is not installed."
command -v magick      &>/dev/null || die "imagemagick is not installed."
command -v fd          &>/dev/null || die "fd is not installed."
command -v notify-send &>/dev/null || die "libnotify is not installed."
awww query             &>/dev/null || die "awww daemon is not running."
[[ -d "$DIR" ]]                    || die "Wallpaper directory not found: $DIR"
[[ -f "$ROFI_THEME" ]]             || die "Rofi theme not found: $ROFI_THEME"

# ── Collect Wallpapers ────────────────────────────────────────────────────────

mkdir -p "$CACHE_DIR" "$HYPR_WALL_DIR"

mapfile -t all_walls < <(fd -a -i -e png -e jpg -e jpeg -e webp . "$DIR" | sort)

[[ ${#all_walls[@]} -eq 0 ]] && die "No wallpapers found in: $DIR"

# ── Generate Thumbnails (parallel) ────────────────────────────────────────────

printf '%s\n' "${all_walls[@]}" | xargs -P4 -I{} bash -c '
    src="{}"
    hash=$(md5sum "$src" | cut -d" " -f1)
    thumb="'"$CACHE_DIR"'/${hash}.png"
    [[ -f "$thumb" ]] || magick "$src" -thumbnail 256x144^ -gravity center -extent 256x144 "$thumb" 2>/dev/null
'

# ── Build Rofi Input ──────────────────────────────────────────────────────────

declare -A label_to_path
ROFI_INPUT=$(mktemp)
trap 'rm -f "$ROFI_INPUT"' EXIT

for file in "${all_walls[@]}"; do
    thumb=$(thumb_path "$file")
    label=$(basename "$file")
    label_to_path["$label"]="$file"
    printf "%s\0icon\x1f%s\n" "$label" "$thumb" >> "$ROFI_INPUT"
done

# ── Launch Rofi ───────────────────────────────────────────────────────────────

chosen_label=$(rofi -dmenu -i -p "󰸉  Wallpaper: " -theme "$ROFI_THEME" < "$ROFI_INPUT")

[[ -z "$chosen_label" ]] && exit 0

# ── Resolve Selection ─────────────────────────────────────────────────────────

wallpaper="${label_to_path[$chosen_label]:-}"
[[ -z "$wallpaper" ]] && die "Could not resolve: $chosen_label"

# ── Copy to Hyprpaper Directory ───────────────────────────────────────────────

ext="${wallpaper##*.}"
HYPR_WALL="$HYPR_WALL_DIR/current.$ext"

# Remove any previous current.* to avoid stale files with different extensions
rm -f "$HYPR_WALL_DIR"/current.*
ln -sf "$wallpaper" "$HYPR_WALL"

cat > "$HYPRPAPER_CONF" <<EOF
preload = $HYPR_WALL
wallpaper = ,$HYPR_WALL
EOF

# Reload hyprpaper live if running
if pgrep -x hyprpaper &>/dev/null; then
    hyprctl hyprpaper preload "$HYPR_WALL"
    hyprctl hyprpaper wallpaper ",$HYPR_WALL"
fi

# ── Apply via awww ────────────────────────────────────────────────────────────

awww img "$wallpaper" \
    --transition-type     "$TRANSITION_TYPE" \
    --transition-fps      "$TRANSITION_FPS" \
    --transition-duration "$TRANSITION_DURATION" \
    --transition-step     120 \
    --transition-pos      "$TRANSITION_POS"

echo "$wallpaper" > "$LAST_WALL"

{
    matugen image "$wallpaper" -m dark -t scheme-expressive \
        --contrast 1.0 --source-color-index 0 \
    && success "Applied: $(basename "$wallpaper")"
} &
