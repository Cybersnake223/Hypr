set -euo pipefail

notify() { notify-send "Wi-Fi" "$1" -i "${2:-network-wireless}"; }

# в”Ђв”Ђ Connection Management в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

manage_connections() {
    local saved
    saved=$(nmcli -g NAME connection show | grep -v '^\s*$' | sort)

    [[ -z "$saved" ]] && { notify "No saved connections found."; return; }

    local chosen
    chosen=$(echo "$saved" | rofi -dmenu -i -p "у°Њ·  Manage Connection: ")
    [[ -z "$chosen" ]] && return

    local action
    action=$(printf 'Connect\nDisconnect\nForget\nShow Details' \
        | rofi -dmenu -i -p "у°’“  Action [$chosen]: ")
    [[ -z "$action" ]] && return

    case "$action" in
        Connect)
            if nmcli connection up "$chosen"; then
                notify "Connected to: $chosen"
            else
                notify "Failed to connect to: $chosen" network-error
            fi
            ;;
        Disconnect)
            if nmcli connection down "$chosen"; then
                notify "Disconnected from: $chosen"
            else
                notify "Failed to disconnect: $chosen" network-error
            fi
            ;;
        Forget)
            local confirm
            confirm=$(printf 'Yes\nNo' | rofi -dmenu -i -p "у°ЂЁ  Forget '$chosen'?")
            [[ "$confirm" == "Yes" ]] || return
            if nmcli connection delete "$chosen"; then
                notify "Forgotten: $chosen"
            else
                notify "Failed to forget: $chosen" network-error
            fi
            ;;
        "Show Details")
            local details
            details=$(nmcli connection show "$chosen" 2>&1)
            echo "$details" | rofi -dmenu -i -p "у°‹Ѕ  $chosen" > /dev/null || true
            ;;
    esac
}

# в”Ђв”Ђ Connect to Network в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

connect_network() {
    notify "Scanning networks..." 

    nmcli device wifi rescan 2>/dev/null || true
    sleep 2

    local wifi_list
    wifi_list=$(nmcli -f SSID,SIGNAL,SECURITY device wifi list \
        | tail -n +2 \
        | awk 'NF && !seen[$0]++' \
        | sort -k2 -rn)

    [[ -z "$wifi_list" ]] && { notify "No networks found." network-error; exit 1; }

    local chosen_network
    chosen_network=$(echo "$wifi_list" | rofi -dmenu -i -p "у°Ђ‚  Network: ")
    [[ -z "$chosen_network" ]] && return

    local ssid
    ssid=$(awk '{print $1}' <<< "$chosen_network")

    connect() {
        if nmcli device wifi connect "$ssid" "$@"; then
            notify "Connected to: $ssid"
        else
            notify "Failed to connect to: $ssid" network-error
            exit 1
        fi
    }

    if nmcli -g NAME connection show | grep -Fxq "$ssid"; then
        connect
    else
        local wifi_password
        wifi_password=$(rofi -dmenu -password -l 0 -p "у°Њ‹  Password: ")
        [[ -z "$wifi_password" ]] && return
        connect password "$wifi_password"
    fi
}

# в”Ђв”Ђ Main Menu в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

main() {
    local mode
    mode=$(printf 'у°Ђ‚  Connect to Network\nу°Њ·  Manage Saved Connections' \
        | rofi -dmenu -i -p "у°–©  Wi-Fi: ")
    [[ -z "$mode" ]] && exit 0

    case "$mode" in
        *"Connect to Network")    connect_network ;;
        *"Manage Saved"*)         manage_connections ;;
    esac
}

main
