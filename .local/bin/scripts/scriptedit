term="${TERMINAL:-kitty}"
dir="${SCRIPTS_DIR:-$HOME/.local/bin/scripts}"

[[ ! -d "$dir" ]] && { notify-send "Script Editor" "Directory not found: $dir"; exit 1; }

selected_file=$(fd . "$dir" -t f | rofi -dmenu -i -p "Edit Script:")

[[ -z "$selected_file" ]] && exit 0

exec $term -e nvim "$selected_file"
