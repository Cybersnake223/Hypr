#!/bin/bash
############################################################################################################

set -euo pipefail

notify() { notify-send "Cache Cleaner" "$1" ${2:+-i "$2"}; }
die()    { notify "$1" dialog-error; exit 1; }

command -v bleachbit &>/dev/null || die "bleachbit is not installed."

declare -a targets=(
    "$HOME/.cache/rofi3.druncache"
    "$HOME/.cache/nsxiv"
    "$HOME/.cache/nvim"
    "$HOME/.local/state/nvim/swap"
)

before=$(du -sb "$HOME/.cache" 2>/dev/null | awk '{print $1}')
notify "Starting cache clean ($(du -hs "$HOME/.cache" | awk '{print $1}') used)"

for target in "${targets[@]}"; do
    [[ -e "$target" ]] && rm -rf "$target"
done

# Only delete nvim undo files older than 30 days (preserve recent undo history)
[[ -d "$HOME/.local/state/nvim/undo" ]] && \
    find "$HOME/.local/state/nvim/undo" -mtime +30 -delete

after=$(du -sb "$HOME/.cache" 2>/dev/null | awk '{print $1}')
freed=$(( (before - after) / 1024 / 1024 ))
notify "App cache cleaned: freed ~${freed}MB"

# Run bleachbit only for cleaners that exist
sys=$(bleachbit -c system.cache zen.cache 2>/dev/null | awk '/Disk space/ {print}' || true)
[[ -n "$sys" ]] && notify "System cache: $sys" || notify "No system cache freed."
