#!/bin/bash

############################################################################################################
##   ______  __      __  _______   ________  _______    ______   __    __   ______   __    __  ________   ##
##  /      \|  \    /  \|       \ |        \|       \  /      \ |  \  |  \ /      \ |  \  /  \|        \  ##
## |  $$$$$$\\$$\  /  $$| $$$$$$$\| $$$$$$$$| $$$$$$$\|  $$$$$$\| $$\ | $$|  $$$$$$\| $$ /  $$| $$$$$$$$  ##
## | $$   \$$ \$$\/  $$ | $$__/ $$| $$__    | $$__| $$| $$___\$$| $$$\| $$| $$__| $$| $$/  $$ | $$__      ##
## | $$        \$$  $$  | $$    $$| $$  \   | $$    $$ \$$    \ | $$$$\ $$| $$    $$| $$  $$  | $$  \     ##
## | $$   __    \$$$$   | $$$$$$$\| $$$$$   | $$$$$$$\ _\$$$$$$\| $$\$$ $$| $$$$$$$$| $$$$$\  | $$$$$     ##
## | $$__/  \   | $$    | $$__/ $$| $$_____ | $$  | $$|  \__| $$| $$ \$$$$| $$  | $$| $$ \$$\ | $$_____   ##
##  \$$    $$   | $$    | $$    $$| $$     \| $$  | $$ \$$    $$| $$  \$$$| $$  | $$| $$  \$$\| $$     \  ##
##   \$$$$$$     \$$     \$$$$$$$  \$$$$$$$$ \$$   \$$  \$$$$$$  \$$   \$$ \$$   \$$ \$$   \$$ \$$$$$$$$  ##
##                                                                                                        ##
## Cache Cleaner                                                                                          ##
## Created by Cybersnake                                                                                  ##
############################################################################################################

set -euo pipefail

notify() { notify-send "Cache Cleaner" "$1" ${2:+-i "$2"}; }

die() { notify "$1" dialog-error; exit 1; }

command -v bleachbit &>/dev/null || die "bleachbit is not installed."

# ── App Cache ─────────────────────────────────────────────────────────────────

declare -a targets=(
    "$HOME/.cache/rofi3.druncache"
    "$HOME/.cache/nsxiv"
    "$HOME/.local/state/nvim/undo"
    "$HOME/.local/state/nvim/swap"
    "$HOME/.cache/nvim"
)

cache_before=$(du -hs "$HOME/.cache" 2>/dev/null | awk '{print $1}')
notify "Cache before cleaning: $cache_before"

for target in "${targets[@]}"; do
    if [[ -e "$target" ]]; then
        rm -rf "$target"
    fi
done

cache_after=$(du -hs "$HOME/.cache" 2>/dev/null | awk '{print $1}')
notify "App cache cleaned: $cache_before → $cache_after"

# ── System Cache ──────────────────────────────────────────────────────────────

sys=$(bleachbit -c system.cache chromium.cache firefox.cache 2>/dev/null \
    | awk '/Disk space/ {print}')

[[ -n "$sys" ]] && notify "System cache cleaned" || notify "No system cache freed."
