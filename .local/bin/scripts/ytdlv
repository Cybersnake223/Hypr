#!/bin/bash
############################################################################################################

set -euo pipefail

dir="$HOME/Videos/Youtube/%(title)s.%(ext)s"

url=$(wl-paste 2>/dev/null | tr -d '[:space:]') || true
[[ -z "$url" ]] && { notify-send -u critical "ytdlv" "Clipboard is empty"; exit 1; }

if ! [[ "$url" =~ ^https?:// ]]; then
    notify-send -u critical "ytdlv" "Invalid URL: $url"
    exit 1
fi

notify-send "ytdlv" "Fetching formats..."

format_list=$(yt-dlp --list-formats "$url" 2>/dev/null \
    | awk 'NR>4 && $3 ~ /video/ {print $1"\t"$2"\t"$3"\t"$4"\t"$6"\t"$7}')

[[ -z "$format_list" ]] && { notify-send -u critical "ytdlv" "No video formats found"; exit 1; }

resolution=$(echo "$format_list" | rofi -dmenu -p "Select Video Format:") || true
[[ -z "$resolution" ]] && { notify-send "ytdlv" "Aborted"; exit 0; }
res_id=$(echo "$resolution" | awk '{print $1}')

audio=$(yt-dlp --list-formats "$url" 2>/dev/null \
    | awk 'NR>4 && $3 ~ /audio/ {print $1"\t"$2"\t"$3"\t"$4"\t"$6"\t"$7}' \
    | rofi -dmenu -p "Select Audio Quality:") || true
[[ -z "$audio" ]] && { notify-send "ytdlv" "Aborted"; exit 0; }
audio_id=$(echo "$audio" | awk '{print $1}')

notify-send "ytdlv" "Downloading..."
yt-dlp -q --format "${res_id}+${audio_id}" -o "$dir" "$url" \
    && notify-send "ytdlv" "✅ Download complete" \
    || notify-send -u critical "ytdlv" "❌ Download failed"
