## |  $$$$$$\\$$\  /  $$| $$$$$$$\| $$$$$$$$| $$$$$$$\|  $$$$$$\| $$\ | $$|  $$$$$$\| $$ /  $$| $$$$$$$$  ##
## | $$   \$$ \$$\/  $$ | $$__/ $$| $$__    | $$__| $$| $$___\$$| $$$\| $$| $$__| $$| $$/  $$ | $$__      ##
## | $$        \$$  $$  | $$    $$| $$  \   | $$    $$ \$$    \ | $$$$\ $$| $$    $$| $$  $$  | $$  \     ##
## | $$   __    \$$$$   | $$$$$$$\| $$$$$   | $$$$$$$\ _\$$$$$$\| $$\$$ $$| $$$$$$$$| $$$$$\  | $$$$$     ##
## | $$__/  \   | $$    | $$__/ $$| $$_____ | $$  | $$|  \__| $$| $$ \$$$$| $$  | $$| $$ \$$\ | $$_____   ##
##  \$$    $$   | $$    | $$    $$| $$     \| $$  | $$ \$$    $$| $$  \$$$| $$  | $$| $$  \$$\| $$     \  ##
##   \$$$$$$     \$$     \$$$$$$$  \$$$$$$$$ \$$   \$$  \$$$$$$  \$$   \$$ \$$   \$$ \$$   \$$ \$$$$$$$$  ##
##                                                                                                        ##
## Bluetooth Script                                                                                       ##
## Created by Cybersnake                                                                                  ##
############################################################################################################

set -euo pipefail

CONNECT_TIMEOUT="${CONNECT_TIMEOUT:-10}"
SCAN_TIMEOUT="${SCAN_TIMEOUT:-10}"
NOTIFY_ICON="${NOTIFY_ICON:-bluetooth}"

for cmd in bluetoothctl bt-device rofi notify-send rfkill; do
    command -v "$cmd" &>/dev/null || { echo "Missing: $cmd" >&2; exit 1; }
done

init_bluetooth() {
    rfkill unblock bluetooth 2>/dev/null || {
        notify-send -u critical -i "$NOTIFY_ICON" "Bluetooth" "Failed to unblock (hard-blocked?)"
        exit 1
    }
    bluetoothctl show 2>/dev/null | grep -q "Powered: yes" && return 0
    bluetoothctl power on >/dev/null 2>&1
    local retries=5
    while (( retries-- > 0 )); do
        bluetoothctl show 2>/dev/null | grep -q "Powered: yes" && return 0
        sleep 0.3
    done
    notify-send -u critical -i "$NOTIFY_ICON" "Bluetooth" "Adapter failed to power on"
    exit 1
}

bt_notify() { notify-send -u "${1:-normal}" -i "$NOTIFY_ICON" "Bluetooth" "$2"; }

get_connected_status() { bt-device -i "$1" 2>/dev/null | awk '/Connected:/{print $2}'; }
is_paired() { bt-device -i "$1" &>/dev/null; }
extract_mac() { [[ "$1" =~ \(([0-9A-Fa-f:]{17})\) ]] && echo "${BASH_REMATCH[1]}"; }
extract_name() { echo "${1% (*}"; }
format_devices() { awk '{mac=$1; $1=""; name=substr($0,2); print name " (" mac ")"}'; }
rofi_menu() { rofi -dmenu -i -p "$1" -l "$2"; }

# Fixed scan: background scan + merge with paired list
run_scan() {
    bt_notify "normal" "Scanning for ${SCAN_TIMEOUT}s..."
    bluetoothctl scan on >/dev/null 2>&1 &
    local scan_pid=$!
    sleep "$SCAN_TIMEOUT"
    kill "$scan_pid" 2>/dev/null || true

    { bluetoothctl devices Paired; bluetoothctl devices; } \
        | grep "^Device" | sed 's/Device //' | sort -u -k1,1
}

connect_device() {
    local mac="$1" name="$2"
    bt_notify "normal" "Connecting to $name..."
    bluetoothctl connect "$mac" >/dev/null 2>&1 &
    local pid=$! i=0
    while (( i++ < CONNECT_TIMEOUT * 2 )); do
        local s; s=$(get_connected_status "$mac")
        if [[ "$s" == "1" || "$s" == "yes" ]]; then
            kill "$pid" 2>/dev/null || true
            bt_notify "normal" "Connected to $name ✓"; return 0
        fi
        sleep 0.5
    done
    kill "$pid" 2>/dev/null || true
    bt_notify "critical" "Failed to connect to $name"; return 1
}

disconnect_device() {
    local mac="$1" name="$2"
    bt_notify "normal" "Disconnecting from $name..."
    bluetoothctl disconnect "$mac" >/dev/null 2>&1 \
        && bt_notify "normal" "Disconnected from $name ✓" \
        || bt_notify "critical" "Failed to disconnect from $name"
}

pair_device() {
    local mac="$1" name="$2"
    bt_notify "normal" "Pairing with $name..."
    bluetoothctl trust "$mac" >/dev/null 2>&1
    bluetoothctl pair "$mac" >/dev/null 2>&1 \
        && bt_notify "normal" "Paired with $name ✓" && return 0
    bt_notify "critical" "Pairing failed with $name"; return 1
}

remove_device() {
    local mac="$1" name="$2"
    bt_notify "normal" "Removing $name..."
    bluetoothctl remove "$mac" >/dev/null 2>&1 \
        && bt_notify "normal" "Removed $name ✓" \
        || bt_notify "critical" "Failed to remove $name"
}

menu_paired_devices() {
    local devices
    devices=$(bt-device -l 2>/dev/null | tail -n +2)
    [[ -z "$devices" ]] && { bt_notify "normal" "No paired devices found."; exit 0; }
    local chosen
    chosen=$(echo "$devices" | rofi_menu "$1" 5)
    [[ -z "$chosen" ]] && exit 0
    echo "$chosen"
}

menu_device_action() {
    local label
    [[ "$2" == "1" || "$2" == "yes" ]] && label="󰂱  Connected" || label="󰂲  Disconnected"
    printf "󰂯  Connect\n󰂲  Disconnect\n󰚃  Remove Device\n󰌍  Back" \
        | rofi_menu "$1  ·  $label" 4
}

flow_toggle() {
    local chosen mac name is_connected
    chosen=$(menu_paired_devices "󰂯 Bluetooth")
    mac=$(extract_mac "$chosen"); name=$(extract_name "$chosen")
    is_connected=$(get_connected_status "$mac")
    [[ "$is_connected" == "1" || "$is_connected" == "yes" ]] \
        && disconnect_device "$mac" "$name" \
        || connect_device "$mac" "$name"
}

flow_manage() {
    local chosen mac name is_connected action
    chosen=$(menu_paired_devices "󰖴 Manage Device")
    mac=$(extract_mac "$chosen"); name=$(extract_name "$chosen")
    is_connected=$(get_connected_status "$mac")
    action=$(menu_device_action "$name" "$is_connected")
    [[ -z "$action" ]] && return
    case "$action" in
        *Disconnect*) disconnect_device "$mac" "$name" ;;
        *Connect*)    connect_device    "$mac" "$name" ;;
        *Remove*)     remove_device     "$mac" "$name" ;;
        *Back*)       return ;;
    esac
}

flow_scan() {
    local all_devices formatted chosen mac name
    all_devices=$(run_scan)
    [[ -z "$all_devices" ]] && { bt_notify "normal" "No devices found."; exit 0; }
    formatted=$(echo "$all_devices" | format_devices)
    chosen=$(echo "$formatted" | rofi_menu "󰂰 Pair Device" 8)
    [[ -z "$chosen" ]] && exit 0
    mac=$(extract_mac "$chosen"); name=$(extract_name "$chosen")
    is_paired "$mac" && connect_device "$mac" "$name" \
        || { pair_device "$mac" "$name" && connect_device "$mac" "$name"; }
}

main_menu() {
    while true; do
        local choice
        choice=$(printf "󰂯  Toggle Device\n󰂰  Scan & Pair New Device\n󰖴  Manage Device" \
            | rofi_menu "󰂱 Bluetooth" 3)
        case "$choice" in
            *Toggle*) flow_toggle ;;
            *Scan*)   flow_scan   ;;
            *Manage*) flow_manage ;;
            *)        exit 0      ;;
        esac
    done
}

init_bluetooth
main_menu
