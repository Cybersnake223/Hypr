#!/bin/bash
############################################################################################################
set -euo pipefail

readonly CONNECT_TIMEOUT="${CONNECT_TIMEOUT:-10}"
readonly SCAN_TIMEOUT="${SCAN_TIMEOUT:-15}"
readonly NOTIFY_ICON="${NOTIFY_ICON:-bluetooth}"

readonly URGENCY_NORMAL="normal"
readonly URGENCY_CRITICAL="critical"

# ---------------------------
# Dependency Check
# ---------------------------
for cmd in bluetoothctl rofi notify-send rfkill; do
    command -v "$cmd" &>/dev/null || {
        echo "Missing: $cmd" >&2
        exit 1
    }
done

PIDS=()
cleanup() {
    for pid in "${PIDS[@]:-}"; do
        kill "$pid" 2>/dev/null || true
    done
}
trap cleanup EXIT INT TERM

bt_notify() {
    notify-send -u "${1:-$URGENCY_NORMAL}" -i "$NOTIFY_ICON" "Bluetooth" "$2"
}

rofi_menu() {
    rofi -dmenu -i -p "$1" -l "$2"
}

get_info() {
    bluetoothctl info "$1" 2>/dev/null
}

is_connected() {
    local info
    info=$(get_info "$1")
    [[ $info =~ Connected:\ yes ]]
}

is_paired() {
    local info
    info=$(get_info "$1")
    [[ $info =~ Paired:\ yes ]]
}

extract_mac() {
    [[ "$1" =~ \(([0-9A-Fa-f:]{17})\) ]] && echo "${BASH_REMATCH[1]}"
}

extract_name() {
    echo "${1% (*}"
}

# ---------------------------
# Bluetooth Init
# ---------------------------
init_bluetooth() {
    rfkill unblock bluetooth 2>/dev/null || true

    if rfkill list bluetooth 2>/dev/null | grep -q "Hard blocked: yes"; then
        bt_notify "$URGENCY_CRITICAL" "Failed to unblock (hard-blocked?)"
        exit 1
    fi

    bluetoothctl show | grep -q "Powered: yes" && return

    bluetoothctl power on >/dev/null 2>&1

    for _ in {1..5}; do
        bluetoothctl show | grep -q "Powered: yes" && return
        sleep 0.3
    done

    bt_notify "$URGENCY_CRITICAL" "Adapter failed to power on"
    exit 1
}

# ---------------------------
# Device Formatting
# ---------------------------
format_devices() {
    while IFS= read -r line; do
        [[ -z $line ]] && continue

        local mac="${line%% *}"
        mac=${mac//-/:}

        local name="${line#* }"
        [[ -z $name ]] && name="$mac"

        printf '%s (%s)\n' "$name" "$mac"
    done
}

# ---------------------------
# Scan
# ---------------------------
run_scan() {
    bt_notify "$URGENCY_NORMAL" "Scanning for ${SCAN_TIMEOUT}s..."

    bluetoothctl scan on >/dev/null 2>&1
    sleep "$SCAN_TIMEOUT"
    bluetoothctl scan off >/dev/null 2>&1

    {
        bluetoothctl devices Paired
        bluetoothctl devices
    } | awk '!seen[$2]++' | sed 's/^Device //'
}

run_bt_action() {
    local action="$1" mac="$2" name="$3"

    bt_notify "$URGENCY_NORMAL" "$action $name..."

    if bluetoothctl "$action" "$mac" >/dev/null 2>&1; then
        bt_notify "$URGENCY_NORMAL" "${action^} succeeded for $name ✓"
        return 0
    else
        bt_notify "$URGENCY_CRITICAL" "${action^} failed for $name"
        return 1
    fi
}

disconnect_device() { run_bt_action disconnect "$1" "$2"; }
remove_device()     { run_bt_action remove     "$1" "$2"; }

# ---------------------------
# Connect
# ---------------------------
connect_device() {
    local mac="$1" name="$2"
    local timeout=$CONNECT_TIMEOUT

    bt_notify "$URGENCY_NORMAL" "Connecting to $name..."

    bluetoothctl connect "$mac" >/dev/null 2>&1 &
    local pid=$!
    PIDS+=("$pid")

    for ((i=0; i < timeout * 2; i++)); do
        if is_connected "$mac"; then
            kill "$pid" 2>/dev/null || true
            bt_notify "$URGENCY_NORMAL" "Connected to $name ✓"
            return 0
        fi
        sleep 0.5
    done

    kill "$pid" 2>/dev/null || true
    bt_notify "$URGENCY_CRITICAL" "Failed to connect to $name"
    return 1
}

# ---------------------------
# Pair
# ---------------------------
pair_device() {
    local mac="$1" name="$2"

    bt_notify "$URGENCY_NORMAL" "Pairing with $name..."

    bluetoothctl agent on >/dev/null 2>&1
    bluetoothctl default-agent >/dev/null 2>&1
    bluetoothctl trust "$mac" >/dev/null 2>&1

    if bluetoothctl pair "$mac" >/dev/null 2>&1; then
        bt_notify "$URGENCY_NORMAL" "Paired with $name ✓"
        return 0
    else
        bt_notify "$URGENCY_CRITICAL" "Pairing failed with $name"
        return 1
    fi
}

# ---------------------------
# Menus
# ---------------------------
menu_paired_devices() {
    local devices chosen

    devices=$(bluetoothctl devices Paired \
        | sed 's/^Device //' | format_devices)

    [[ -z $devices ]] && {
        bt_notify "$URGENCY_NORMAL" "No paired devices found."
        return 1
    }

    chosen=$(echo "$devices" | rofi_menu "$1" 5)
    [[ -z $chosen ]] && return 1

    echo "$chosen"
}

menu_device_action() {
    local name="$1" mac="$2"

    local label="󰂲  Disconnected"
    is_connected "$mac" && label="󰂱  Connected"

    printf "󰂯  Connect\n󰂲  Disconnect\n󰚃  Remove Device\n󰌍  Back" \
        | rofi_menu "$name  ·  $label" 4
}

# ---------------------------
# Flow
# ---------------------------
flow_toggle() {
    local chosen mac name

    chosen=$(menu_paired_devices "󰂯 Bluetooth") || return
    mac=$(extract_mac "$chosen")
    name=$(extract_name "$chosen")

    if is_connected "$mac"; then
        disconnect_device "$mac" "$name"
    else
        connect_device "$mac" "$name"
    fi
}

flow_manage() {
    local chosen mac name action

    chosen=$(menu_paired_devices "󰖴 Manage Device") || return
    mac=$(extract_mac "$chosen")
    name=$(extract_name "$chosen")

    action=$(menu_device_action "$name" "$mac")
    [[ -z $action ]] && return

    case "$action" in
        *Disconnect*) disconnect_device "$mac" "$name" ;;
        *Connect*)    connect_device    "$mac" "$name" ;;
        *Remove*)     remove_device     "$mac" "$name" ;;
    esac
}

flow_scan() {
    local all_devices formatted chosen mac name

    all_devices=$(run_scan)
    [[ -z $all_devices ]] && {
        bt_notify "$URGENCY_NORMAL" "No devices found."
        return
    }

    formatted=$(echo "$all_devices" | format_devices)

    chosen=$(echo "$formatted" | rofi_menu "󰂰 Pair Device" 8)
    [[ -z $chosen ]] && return

    mac=$(extract_mac "$chosen")
    name=$(extract_name "$chosen")

    [[ -z $name || $name == "$mac" ]] && name="$mac"

    if is_paired "$mac"; then
        connect_device "$mac" "$name"
    else
        pair_device "$mac" "$name" && connect_device "$mac" "$name"
    fi
}

# ---------------------------
# Main Menu
# ---------------------------
main_menu() {
    while true; do
        local choice

        choice=$(printf "󰂯  Toggle Device\n󰂰  Scan & Pair New Device\n󰖴  Manage Device" \
            | rofi_menu "󰂱 Bluetooth" 3)

        case "$choice" in
            *Toggle*) flow_toggle ;;
            *Scan*)   flow_scan   ;;
            *Manage*) flow_manage ;;
            *)        exit 0      ;;
        esac
    done
}

init_bluetooth
main_menu
