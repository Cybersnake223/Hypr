#!/bin/bash

############################################################################################################
##   ______  __      __  _______   ________  _______    ______   __    __   ______   __    __  ________   ##
##  /      \|  \    /  \|       \ |        \|       \  /      \ |  \  |  \ /      \ |  \  /  \|        \  ##
## |  $$$$$$\\$$\  /  $$| $$$$$$$\| $$$$$$$$| $$$$$$$\|  $$$$$$\| $$\ | $$|  $$$$$$\| $$ /  $$| $$$$$$$$  ##
## | $$   \$$ \$$\/  $$ | $$__/ $$| $$__    | $$__| $$| $$___\$$| $$$\| $$| $$__| $$| $$/  $$ | $$__      ##
## | $$        \$$  $$  | $$    $$| $$  \   | $$    $$ \$$    \ | $$$$\ $$| $$    $$| $$  $$  | $$  \     ##
## | $$   __    \$$$$   | $$$$$$$\| $$$$$   | $$$$$$$\ _\$$$$$$\| $$\$$ $$| $$$$$$$$| $$$$$\  | $$$$$     ##
## | $$__/  \   | $$    | $$__/ $$| $$_____ | $$  | $$|  \__| $$| $$ \$$$$| $$  | $$| $$ \$$\ | $$_____   ##
##  \$$    $$   | $$    | $$    $$| $$     \| $$  | $$ \$$    $$| $$  \$$$| $$  | $$| $$  \$$\| $$     \  ##
##   \$$$$$$     \$$     \$$$$$$$  \$$$$$$$$ \$$   \$$  \$$$$$$  \$$   \$$ \$$   \$$ \$$   \$$ \$$$$$$$$  ##
##                                                                                                        ##
## Bluetooth Script                                                                                       ##
## Created by Cybersnake                                                                                  ##
############################################################################################################

set -euo pipefail

CONNECT_TIMEOUT="${CONNECT_TIMEOUT:-10}"
SCAN_TIMEOUT="${SCAN_TIMEOUT:-15}"
NOTIFY_ICON="${NOTIFY_ICON:-bluetooth}"

for cmd in bluetoothctl rofi notify-send rfkill; do
    command -v "$cmd" &>/dev/null || { echo "Missing: $cmd" >&2; exit 1; }
done

init_bluetooth() {
    rfkill unblock bluetooth 2>/dev/null || true
    if rfkill list bluetooth 2>/dev/null | grep -q "Hard blocked: yes"; then
        notify-send -u critical -i "$NOTIFY_ICON" "Bluetooth" "Failed to unblock (hard-blocked?)"
        exit 1
    fi
    bluetoothctl show 2>/dev/null | grep -q "Powered: yes" && return 0
    bluetoothctl power on >/dev/null 2>&1
    local retries=5
    while (( retries-- > 0 )); do
        bluetoothctl show 2>/dev/null | grep -q "Powered: yes" && return 0
        sleep 0.3
    done
    notify-send -u critical -i "$NOTIFY_ICON" "Bluetooth" "Adapter failed to power on"
    exit 1
}

bt_notify()     { notify-send -u "${1:-normal}" -i "$NOTIFY_ICON" "Bluetooth" "$2"; }
get_connected() { bluetoothctl info "$1" 2>/dev/null | awk '/Connected:/{print $2}'; }
is_paired()     { bluetoothctl info "$1" 2>/dev/null | grep -q "Paired: yes"; }
extract_mac()   { [[ "$1" =~ \(([0-9A-Fa-f:]{17})\) ]] && echo "${BASH_REMATCH[1]}"; }
extract_name()  { echo "${1% (*}"; }
rofi_menu()     { rofi -dmenu -i -p "$1" -l "$2"; }

format_devices() {
    while IFS= read -r line; do
        [[ -z "$line" ]] && continue
        local mac name resolved
        mac=$(echo "$line" | awk '{print $1}' | tr '-' ':')
        name=$(echo "$line" | awk '{$1=""; sub(/^ /, ""); print}')
        if [[ -z "$name" || "$name" =~ ^[[:space:]]*$ ]]; then
            resolved=$(bluetoothctl info "$mac" 2>/dev/null \
                | awk '/Name:/{$1=""; sub(/^ /, ""); print}')
            name="${resolved:-$mac}"
        fi
        echo "$name ($mac)"
    done
}

run_scan() {
    bt_notify "normal" "Scanning for ${SCAN_TIMEOUT}s..."
    bluetoothctl --timeout "$SCAN_TIMEOUT" scan on &>/dev/null || true
    { bluetoothctl devices Paired; bluetoothctl devices; } \
        | grep "^Device" | sed 's/^Device //' \
        | awk '!seen[$1]++'
}

connect_device() {
    local mac="$1" name="$2"
    local -i timeout="${CONNECT_TIMEOUT}"
    bt_notify "normal" "Connecting to $name..."
    bluetoothctl connect "$mac" >/dev/null 2>&1 &
    local pid=$! i=0
    while (( i++ < timeout * 2 )); do
        local s; s=$(get_connected "$mac")
        if [[ "$s" == "1" || "$s" == "yes" ]]; then
            kill "$pid" 2>/dev/null || true
            bt_notify "normal" "Connected to $name ✓"; return 0
        fi
        sleep 0.5
    done
    kill "$pid" 2>/dev/null || true
    bt_notify "critical" "Failed to connect to $name"; return 1
}

disconnect_device() {
    local mac="$1" name="$2"
    bt_notify "normal" "Disconnecting from $name..."
    if bluetoothctl disconnect "$mac" >/dev/null 2>&1; then
        bt_notify "normal" "Disconnected from $name ✓"
    else
        bt_notify "critical" "Failed to disconnect from $name"
    fi
}

pair_device() {
    local mac="$1" name="$2"
    bt_notify "normal" "Pairing with $name..."
    bluetoothctl agent on >/dev/null 2>&1
    bluetoothctl default-agent >/dev/null 2>&1
    bluetoothctl trust "$mac" >/dev/null 2>&1
    if bluetoothctl pair "$mac" >/dev/null 2>&1; then
        bt_notify "normal" "Paired with $name ✓"; return 0
    fi
    bt_notify "critical" "Pairing failed with $name"; return 1
}

remove_device() {
    local mac="$1" name="$2"
    bt_notify "normal" "Removing $name..."
    if bluetoothctl remove "$mac" >/dev/null 2>&1; then
        bt_notify "normal" "Removed $name ✓"
    else
        bt_notify "critical" "Failed to remove $name"
    fi
}

menu_paired_devices() {
    local devices
    devices=$(bluetoothctl devices Paired 2>/dev/null \
        | sed 's/^Device //' | format_devices)
    [[ -z "$devices" ]] && { bt_notify "normal" "No paired devices found."; return 1; }
    local chosen
    chosen=$(echo "$devices" | rofi_menu "$1" 5)
    [[ -z "$chosen" ]] && return 1
    echo "$chosen"
}

menu_device_action() {
    local name="$1" mac="$2"
    local s; s=$(get_connected "$mac")
    local label
    [[ "$s" == "1" || "$s" == "yes" ]] && label="󰂱  Connected" || label="󰂲  Disconnected"
    printf "󰂯  Connect\n󰂲  Disconnect\n󰚃  Remove Device\n󰌍  Back" \
        | rofi_menu "$name  ·  $label" 4
}

flow_toggle() {
    local chosen mac name s
    chosen=$(menu_paired_devices "󰂯 Bluetooth") || return
    mac=$(extract_mac "$chosen"); name=$(extract_name "$chosen")
    s=$(get_connected "$mac")
    [[ "$s" == "1" || "$s" == "yes" ]] \
        && disconnect_device "$mac" "$name" \
        || connect_device    "$mac" "$name"
}

flow_manage() {
    local chosen mac name action
    chosen=$(menu_paired_devices "󰖴 Manage Device") || return
    mac=$(extract_mac "$chosen"); name=$(extract_name "$chosen")
    action=$(menu_device_action "$name" "$mac")
    [[ -z "$action" ]] && return
    case "$action" in
        *Disconnect*) disconnect_device "$mac" "$name" ;;
        *Connect*)    connect_device    "$mac" "$name" ;;
        *Remove*)     remove_device     "$mac" "$name" ;;
        *Back*)       return ;;
    esac
}

flow_scan() {
    local all_devices formatted chosen mac name
    all_devices=$(run_scan)
    [[ -z "$all_devices" ]] && { bt_notify "normal" "No devices found."; return; }
    formatted=$(echo "$all_devices" | format_devices)
    chosen=$(echo "$formatted" | rofi_menu "󰂰 Pair Device" 8)
    [[ -z "$chosen" ]] && return
    mac=$(extract_mac "$chosen"); name=$(extract_name "$chosen")
    [[ -z "$name" || "$name" == "$mac" ]] && name="$mac"
    if is_paired "$mac"; then
        connect_device "$mac" "$name"
    else
        pair_device "$mac" "$name" && connect_device "$mac" "$name"
    fi
}

main_menu() {
    while true; do
        local choice
        choice=$(printf "󰂯  Toggle Device\n󰂰  Scan & Pair New Device\n󰖴  Manage Device" \
            | rofi_menu "󰂱 Bluetooth" 3)
        case "$choice" in
            *Toggle*) flow_toggle ;;
            *Scan*)   flow_scan   ;;
            *Manage*) flow_manage ;;
            *)        exit 0      ;;
        esac
    done
}

init_bluetooth
main_menu
