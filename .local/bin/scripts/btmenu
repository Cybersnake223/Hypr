CONNECT_TIMEOUT=10
SCAN_TIMEOUT=10
NOTIFY_ICON="bluetooth"

# в”Ђв”Ђв”Ђ Init в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

init_bluetooth() {
    if ! rfkill unblock bluetooth 2>/dev/null; then
        notify-send -u critical -i "$NOTIFY_ICON" "Bluetooth" \
            "Failed to unblock radio (hard-blocked?)"
        exit 1
    fi
    bluetoothctl power on > /dev/null 2>&1
}

# в”Ђв”Ђв”Ђ Helpers в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

bt_notify() {
    local urgency="${1:-normal}"
    notify-send -u "$urgency" -i "$NOTIFY_ICON" "Bluetooth" "$2"
}

get_connected_status() {
    bt-device -i "$1" 2>/dev/null | awk '/Connected:/{print $2}'
}

is_paired() {
    bt-device -i "$1" &>/dev/null
}

extract_mac() {
    echo "$1" | sed 's/.*(\(.*\))/\1/'
}

extract_name() {
    echo "$1" | sed 's/ (.*//'
}

format_devices() {
    # Input:  "MAC Name"
    # Output: "Name (MAC)"
    awk '{mac=$1; $1=""; name=substr($0,2); print name " (" mac ")"}'
}

rofi_menu() {
    local prompt="$1" lines="$2"
    rofi -dmenu -i -p "$prompt" -l "$lines"
}

# в”Ђв”Ђв”Ђ Scan в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

run_scan() {
    bt_notify "normal" "Scanning for ${SCAN_TIMEOUT}s..."

    # Single bluetoothctl session: scan в†’ wait в†’ devices в†’ quit
    local scan_output
    scan_output=$(
        {
            echo "scan on"
            sleep "$SCAN_TIMEOUT"
            echo "devices"
            echo "quit"
        } | bluetoothctl 2>/dev/null
    )

    # Extract discovered devices from live scan output lines
    local discovered
    discovered=$(echo "$scan_output" \
        | grep -E '^\[.*\]\s*Device [0-9A-F:]{17}' \
        | sed 's/.*Device //' \
        | sort -u -k1,1)

    # Merge with already-paired devices, deduplicate by MAC
    local paired
    paired=$(bluetoothctl devices | sed 's/Device //')

    printf "%s\n%s" "$discovered" "$paired" \
        | grep -v '^$' \
        | sort -u -k1,1
}

# в”Ђв”Ђв”Ђ Actions в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

connect_device() {
    local mac="$1" name="$2"

    bt_notify "normal" "Connecting to $name..."
    if bluetoothctl --timeout "$CONNECT_TIMEOUT" connect "$mac" > /dev/null 2>&1; then
        bt_notify "normal" "Connected to $name вњ“"
        return 0
    fi

    # BlueZ race condition fallback
    sleep 1
    local check
    check=$(get_connected_status "$mac")
    if [ "$check" = "1" ] || [ "$check" = "yes" ]; then
        bt_notify "normal" "Connected to $name вњ“"
        return 0
    fi

    bt_notify "critical" "Failed to connect to $name"
    return 1
}

disconnect_device() {
    local mac="$1" name="$2"
    bt_notify "normal" "Disconnecting from $name..."
    bluetoothctl disconnect "$mac" > /dev/null 2>&1
}

pair_device() {
    local mac="$1" name="$2"

    bt_notify "normal" "Pairing with $name..."
    bluetoothctl trust "$mac" > /dev/null 2>&1

    if bluetoothctl pair "$mac" > /dev/null 2>&1; then
        bt_notify "normal" "Paired with $name вњ“"
        return 0
    fi

    bt_notify "critical" "Pairing failed with $name"
    return 1
}

remove_device() {
    local mac="$1" name="$2"
    bt_notify "normal" "Removing $name..."
    bluetoothctl remove "$mac" > /dev/null 2>&1 \
        && bt_notify "normal" "Removed $name вњ“" \
        || bt_notify "critical" "Failed to remove $name"
}

# в”Ђв”Ђв”Ђ Menus в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

menu_paired_devices() {
    local prompt="$1"

    local devices
    devices=$(bt-device -l | tail -n +2)

    if [ -z "$devices" ]; then
        bt_notify "normal" "No paired devices found."
        exit 0
    fi

    local chosen
    chosen=$(echo "$devices" | rofi_menu "$prompt" 5)
    [ -z "$chosen" ] && exit 0

    echo "$chosen"
}

menu_device_action() {
    local name="$1" is_connected="$2"

    local status_label
    if [ "$is_connected" = "1" ] || [ "$is_connected" = "yes" ]; then
        status_label="у°‚±  Connected"
    else
        status_label="у°‚І  Disconnected"
    fi

    printf "у°‚Ї  Connect\nу°‚І  Disconnect\nу°љѓ  Remove Device\nу°ЊЌ  Back" \
        | rofi_menu "$name  В·  $status_label" 4
}

# в”Ђв”Ђв”Ђ Flows в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

flow_toggle() {
    local chosen
    chosen=$(menu_paired_devices "у°‚Ї Bluetooth")

    local mac name is_connected
    mac=$(extract_mac "$chosen")
    name=$(extract_name "$chosen")
    is_connected=$(get_connected_status "$mac")

    if [ "$is_connected" = "1" ] || [ "$is_connected" = "yes" ]; then
        disconnect_device "$mac" "$name"
    else
        connect_device "$mac" "$name"
    fi
}

flow_manage() {
    local chosen
    chosen=$(menu_paired_devices "у°‚Ї Manage Device")

    local mac name is_connected
    mac=$(extract_mac "$chosen")
    name=$(extract_name "$chosen")
    is_connected=$(get_connected_status "$mac")

    local action
    action=$(menu_device_action "$name" "$is_connected")
    [ -z "$action" ] && exit 0

    case "$action" in
        *"Connect"*)    connect_device "$mac" "$name" ;;
        *"Disconnect"*) disconnect_device "$mac" "$name" ;;
        *"Remove"*)     remove_device "$mac" "$name" ;;
        *"Back"*)       main_menu ;;
    esac
}

flow_scan() {
    local all_devices
    all_devices=$(run_scan)

    if [ -z "$all_devices" ]; then
        bt_notify "normal" "No devices found during scan."
        exit 0
    fi

    local formatted
    formatted=$(echo "$all_devices" | format_devices)

    local chosen
    chosen=$(echo "$formatted" | rofi_menu "у°‚° Pair Device" 8)
    [ -z "$chosen" ] && exit 0

    local mac name
    mac=$(extract_mac "$chosen")
    name=$(extract_name "$chosen")

    if is_paired "$mac"; then
        # Already paired вЂ” go straight to connect
        connect_device "$mac" "$name"
    else
        pair_device "$mac" "$name" && connect_device "$mac" "$name"
    fi
}

# в”Ђв”Ђв”Ђ Main в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

main_menu() {
    local choice
    choice=$(printf \
        "у°‚Ї  Toggle Device\nу°‚°  Scan & Pair New Device\nу°–ґ  Manage Device" \
        | rofi_menu "у°‚± Bluetooth" 3)

    case "$choice" in
        *"Toggle"*)  flow_toggle ;;
        *"Scan"*)    flow_scan ;;
        *"Manage"*)  flow_manage ;;
        *)           exit 0 ;;
    esac
}

init_bluetooth
main_menu
