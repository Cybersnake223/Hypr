set -euo pipefail

term="${TERMINAL:-foot}"
dir="${PYTHON_DIR:-$HOME/Python}"

[[ -d "$dir" ]] || { notify-send "pfiles" "Directory not found: $dir"; exit 1; }

selected=$(fd . "$dir" -t f | rofi -dmenu -i -p "Select File:") || true
[[ -z "$selected" ]] && { notify-send "pfiles" "No file selected."; exit 0; }

exec "$term" -e nvim "$selected"
