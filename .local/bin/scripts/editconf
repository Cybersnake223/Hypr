## |  $$$$$$\\$$\  /  $$| $$$$$$$\| $$$$$$$$| $$$$$$$\|  $$$$$$\| $$\ | $$|  $$$$$$\| $$ /  $$| $$$$$$$$  ##
## | $$   \$$ \$$\/  $$ | $$__/ $$| $$__    | $$__| $$| $$___\$$| $$$\| $$| $$__| $$| $$/  $$ | $$__      ##
## | $$        \$$  $$  | $$    $$| $$  \   | $$    $$ \$$    \ | $$$$\ $$| $$    $$| $$  $$  | $$  \     ##
## | $$   __    \$$$$   | $$$$$$$\| $$$$$   | $$$$$$$\ _\$$$$$$\| $$\$$ $$| $$$$$$$$| $$$$$\  | $$$$$     ##
## | $$__/  \   | $$    | $$__/ $$| $$_____ | $$  | $$|  \__| $$| $$ \$$$$| $$  | $$| $$ \$$\ | $$_____   ##
##  \$$    $$   | $$    | $$    $$| $$     \| $$  | $$ \$$    $$| $$  \$$$| $$  | $$| $$  \$$\| $$     \  ##
##   \$$$$$$     \$$     \$$$$$$$  \$$$$$$$$ \$$   \$$  \$$$$$$  \$$   \$$ \$$   \$$ \$$   \$$ \$$$$$$$$  ##
##                                                                                                        ##
## Config Edit Script                                                                                     ##
## Created by Cybersnake                                                                                  ##
############################################################################################################

term="${TERMINAL:-foot}"

declare -A configs=(
    [aliases]="$HOME/.config/zsh/.zsh_aliases"
    [anyrun]="$HOME/.config/anyrun/config.ron"
    [cava]="$HOME/.config/cava/config"
    [foot]="$HOME/.config/foot/foot.ini"
    [hyprland]="$HOME/.config/hypr/hyprland.conf"
    [hyprlock]="$HOME/.config/hypr/hyprlock.conf"
    [kitty]="$HOME/.config/kitty/kitty.conf"
    [mako]="$HOME/.config/mako/config"
    [mpv]="$HOME/.config/mpv/mpv.conf"
    [mpv-input]="$HOME/.config/mpv/input.conf"
    [nvim]="$HOME/.config/nvim/init.lua"
    [rofi]="$HOME/.config/rofi/config.rasi"
    [waybar]="$HOME/.config/waybar/config.jsonc"
    [waybar-Style]="$HOME/.config/waybar/style.css"
    [yay]="$HOME/.config/yay/config.json"
    [yt-dlp]="$HOME/.config/yt-dlp/config"
    [yazi]="$HOME/.config/yazi/yazi.toml"
    [zsh]="$HOME/.config/zsh/.zshrc"
)

choice=$(printf '%s\n' "${!configs[@]}" | sort | rofi -dmenu -i -p 'Edit config file: ')

[[ -z "$choice" ]] && exit 0

config_path="${configs[$choice]}"

if [[ -z "$config_path" ]]; then
    notify-send "Config Editor" "Unknown config: $choice"
    exit 1
fi

if [[ ! -f "$config_path" ]]; then
    notify-send "Config Editor" "File not found: $config_path"
    exit 1
fi

exec $term -e nvim "$config_path"
