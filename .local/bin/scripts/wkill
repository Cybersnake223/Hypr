#!/bin/bash
set -euo pipefail

_kill() {
  local name="$1" label="$2"
  if pkill -x "$name" 2>/dev/null; then
    [[ -n "$label" ]] && notify-send "$label" "Killed"
  fi
}

_kill gvfsd    "Gvfs"
_kill aria2c   "Aria2 Server"
_kill tumblerd "Thumbnail Daemon"
_kill xfconfd  "XFConf Daemon"

if pkill -x wl-clip-persist 2>/dev/null; then
  notify-send "Clipboard" "Restarted"
  wl-clip-persist -c both &
fi

command -v trash-empty &>/dev/null && trash-empty -f
command -v yazi &>/dev/null && yazi --clear-cache
