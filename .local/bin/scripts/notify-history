#!/bin/bash

raw=$(makoctl history 2>/dev/null) || { notify-send "Notification History" "No history available"; exit 0; }
[[ -z "$raw" ]] && { notify-send "Notification History" "History is empty"; exit 0; }

# Parse summary lines cleanly
entries=$(echo "$raw" | grep -oP '"summary":\s*"\K[^"]+' | head -20)
[[ -z "$entries" ]] && { notify-send "Notification History" "Could not parse history"; exit 0; }

chosen=$(echo "$entries" | rofi -dmenu -i -p "󰂚 Notifications")
[[ -z "$chosen" ]] && exit 0

echo -n "$chosen" | wl-copy
notify-send "Copied" "$chosen" -t 1500
