#!/bin/bash

set -euo pipefail

mapfile -t files < <(fd . ~/Videos ~/Downloads -e mkv -e mp4 -e webm | sort)
[[ ${#files[@]} -eq 0 ]] && { notify-send "watchvid" "No video files found."; exit 0; }

selected=$(printf '%s\n' "${files[@]}" | rofi -dmenu -i -p "Select a file:") || true
[[ -z "$selected" ]] && { notify-send "watchvid" "No file selected."; exit 0; }

exec mpv "$selected"
