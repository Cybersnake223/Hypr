if command -v rofimoji &>/dev/null; then
    rofimoji --action clipboard
else
    sed '1,/^### DATA ###$/d' "$0" | rofi -dmenu -i -p "Emoji" | cut -d ' ' -f 1 | tr -d '\n' | wl-copy
fi

exit

