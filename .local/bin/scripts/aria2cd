#!/bin/bash

set -euo pipefail

pkill -x aria2c 2>/dev/null || true
sleep 0.3

aria2c -j5 -x15 -k25M \
    --enable-rpc=true \
    --rpc-listen-all=false \
    --daemon=true \
    --always-resume=true

sleep 0.5
pgrep -x aria2c &>/dev/null \
    && notify-send "Aria2" "Daemon Started" \
    || notify-send -u critical "Aria2" "Failed to start daemon"
