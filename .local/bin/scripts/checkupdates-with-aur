#!/bin/bash
set -euo pipefail

notify() { notify-send "checkupdates" "$1"; }

official=$(checkupdates 2>/dev/null) || true
aur=$(yay -Qua 2>/dev/null | awk '{print $1, $2, "->", $3}') || true

if [[ -z "$official$aur" ]]; then
    exit 2
fi

[[ -n "$official" ]] && echo "$official"
[[ -n "$aur" ]]      && echo "$aur"
