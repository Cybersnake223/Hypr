#!/bin/bash
############################################################################################################

set -euo pipefail

DIR="$HOME/.config"
rofi_cmd="rofi -theme $DIR/rofi/powermenu.rasi"

uptime=$(uptime -p | sed -e 's/up //g')

bat_health=$(upower -i "$(upower -e | grep -i 'battery' | head -1)" 2>/dev/null \
    | rg capacity | awk '{print$2}' || echo "N/A")

# Options
Shutdown="¯ºÇ"
Reboot="¯ºä"
Lock="¯ªÅ"
Suspend="¯ªú"
Logout="¯ªæ"

options="$Shutdown\n$Reboot\n$Lock\n$Suspend\n$Logout"


# Show menu
chosen="$(echo -e "$options" | $rofi_cmd -p "Uptime <=> $uptime" -dmenu)"

# Command for specific choices
case $chosen in
"$Shutdown")
	systemctl poweroff
;;
"$Reboot")
	systemctl reboot
;;
"$Suspend")
	systemctl suspend
;;
"$Lock")
  hyprlock
;;
"$Logout")
  hyprshutdown
;;
esac
